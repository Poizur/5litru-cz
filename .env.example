# === SUPABASE (own project for 5litru.cz, NOT shared with olivator.cz) ===
# Create new project: https://supabase.com/dashboard → New project
#   Name: 5litru
#   Region: Frankfurt (EU)
# Copy values from Settings → API after the project is created.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Only used by Supabase CLI for db push / db reset. Not read by the app.
SUPABASE_DB_PASSWORD=

# === ANTHROPIC ===
# Used by /admin AI review draft generation. Server-side only.
ANTHROPIC_API_KEY=

# === ADMIN AUTH ===
# Comma-separated list of emails allowed into /admin/* via Supabase magic link.
ADMIN_ALLOWED_EMAILS=m.navratil01@seznam.cz

# === AFFILIATE (eHub) ===
# 32-char hash from eHub dashboard. Replace placeholder before publishing.
EHUB_TRACKING_HASH=<EHUB_HASH_TODO>

# === DEPLOY ===
# Railway redeploy webhook — admin calls this after publishing a new product
# so next.config.js redirects() picks up the new affiliate URL.
RAILWAY_REDEPLOY_WEBHOOK=

# === MISC ===
PORT=3000
NODE_ENV=production
