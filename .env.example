# === SUPABASE (own project for 5litru.cz, NOT shared with olivator.cz) ===
# Create new project: https://supabase.com/dashboard → New project
#   Name: 5litru
#   Region: Frankfurt (EU)
# Copy values from Settings → API after the project is created.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Only used by Supabase CLI for db push / db reset. Not read by the app.
SUPABASE_DB_PASSWORD=

# === ANTHROPIC ===
# Used by /admin AI review draft generation. Server-side only.
ANTHROPIC_API_KEY=

# === ADMIN AUTH ===
# Single shared password — doubles as HMAC signing secret for the session cookie.
# Min 16 chars. Generate with: openssl rand -base64 24
ADMIN_SECRET_KEY=
# (reserved for future migration to Supabase Auth magic link)
ADMIN_ALLOWED_EMAILS=m.navratil01@seznam.cz
# Recipient of system notifications (Resend → italienasbavi@google.com etc).
ADMIN_NOTIFICATION_EMAIL=

# === RESEND (transactional email) ===
# Resend account is shared with Olivator; this API key should be a NEW key
# scoped to the redakce.5litru.cz domain (Resend → API Keys → Create).
RESEND_API_KEY=
# From: brand <local@subdomain>. Subdomain MUST be verified in Resend dashboard
# (DKIM/SPF/DMARC records added to Wedos DNS).
RESEND_FROM_EMAIL="5litru.cz <info@redakce.5litru.cz>"
# Webhook signing secret (Resend Dashboard → Webhooks → 5litru endpoint → Secret).
RESEND_WEBHOOK_SECRET=

# === AFFILIATE (eHub) ===
# 32-char hash from eHub dashboard. Replace placeholder before publishing.
EHUB_TRACKING_HASH=<EHUB_HASH_TODO>

# === DEPLOY ===
# Railway redeploy webhook — admin calls this after publishing a new product
# so next.config.js redirects() picks up the new affiliate URL.
RAILWAY_REDEPLOY_WEBHOOK=

# === MISC ===
PORT=3000
NODE_ENV=production
